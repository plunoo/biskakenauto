# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=change_this_to_a_secure_random_string

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://bisadmin.rpnmore.com

# Database Provider: "firebase" or "postgres" (default: firebase)
DB_PROVIDER=firebase

# Firebase (option A: service account JSON string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}
# Firebase (option B: application default credentials)
FIREBASE_PROJECT_ID=your-firebase-project-id

# PostgreSQL (option A: connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biskaken_auto
# PostgreSQL (option B: individual params)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biskaken_auto
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
